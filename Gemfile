source 'https://rubygems.org'

group :jekyll_plugins do
  gem 'jekyll'
  gem 'jekyll-feed'
  gem 'jekyll-sitemap'
  gem 'jekyll-redirect-from'
  gem 'jemoji'
  gem 'webrick', '~> 1.8'
end

gem 'github-pages'
gem 'connection_pool', '2.5.0'

# Ruby 3.4+ removed these from the default gems. They are needed for local
# Jekyll 3.9 previews on modern Ruby. Harmless for the GitHub Pages build
# (GitHub Pages resolves dependencies server-side from the github-pages gem).
gem 'csv'
gem 'base64'
gem 'bigdecimal'
gem 'logger'
